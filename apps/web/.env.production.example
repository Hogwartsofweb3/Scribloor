# ==========================================
# SOLSCRIBE PRODUCTION ENVIRONMENT VARIABLES
# ==========================================

# 1. Privy (Authentication)
# Get these from https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID="your-privy-app-id"
PRIVY_APP_SECRET="your-privy-app-secret"

# 2. Database (Neon Postgres via Drizzle)
# Get from Neon Console. Use the pooled connection for DATABASE_URL and unpooled for migrations.
DATABASE_URL="postgres://user:password@endpoint.neon.tech/neondb?sslmode=require&pooler=true"
DATABASE_URL_UNPOOLED="postgres://user:password@endpoint.neon.tech/neondb?sslmode=require"

# 3. Redis & Rate Limiting (Upstash)
# Get from Upstash Console
UPSTASH_REDIS_REST_URL="https://your-upstash-redis-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-token"

# 4. Solana & Payments (Helius)
# Get from Helius Dashboard
NEXT_PUBLIC_HELIUS_RPC_URL="https://mainnet.helius-rpc.com/?api-key=your-key"
HELIUS_API_KEY="your-helius-api-key"
HELIUS_WEBHOOK_SECRET="your-secure-webhook-secret"
NEXT_PUBLIC_PLATFORM_FEE_WALLET="your-platform-solana-wallet-address"

# 5. Email (Resend)
# Get from Resend Dashboard
RESEND_API_KEY="re_your-resend-api-key"
EMAIL_FROM="Solscribe <hello@yourdomain.com>"

# 6. Storage (UploadThing)
# Get from UploadThing Dashboard
UPLOADTHING_SECRET="sk_live_your-uploadthing-secret"
UPLOADTHING_APP_ID="your-uploadthing-app-id"

# 7. Monitoring & Observability (Sentry)
# Get from Sentry Project Settings
SENTRY_DSN="https://key@sentry.io/id"
NEXT_PUBLIC_SENTRY_DSN="https://key@sentry.io/id"
SENTRY_AUTH_TOKEN="your-sentry-auth-token-for-source-maps"

# 8. Vercel Cron
# Provide a secure random string to authenticate cron requests
CRON_SECRET="your-secure-cron-secret"
