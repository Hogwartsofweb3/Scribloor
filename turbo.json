{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "**/.env.*local"
  ],
  "globalEnv": [
    "DATABASE_URL",
    "NEXT_PUBLIC_PRIVY_APP_ID",
    "PRIVY_APP_ID",
    "PRIVY_APP_SECRET",
    "NEXT_PUBLIC_HELIUS_RPC_URL",
    "HELIUS_API_KEY",
    "UPSTASH_REDIS_REST_URL",
    "UPSTASH_REDIS_REST_TOKEN",
    "RESEND_API_KEY",
    "NEXT_PUBLIC_APP_URL",
    "NEXT_PUBLIC_PLATFORM_FEE_WALLET",
    "HELIUS_WEBHOOK_SECRET",
    "CRON_SECRET",
    "NEXT_PUBLIC_VAPID_PUBLIC_KEY",
    "VAPID_PRIVATE_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**"
      ]
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    },
    "type-check": {
      "dependsOn": [
        "^type-check"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
